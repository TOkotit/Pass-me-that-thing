{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "32bdb21469e94f2f8af6b55f9522b32d",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "GetMultipleVision (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -629.9998779296875,
            "y": 585.3333129882813,
            "width": 255.333251953125,
            "height": 96.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "af6fa02224304cb8b089fe1c77f7c824"
        },
        {
            "m_Id": "c5bf93d69949418da67621234ac9d936"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 0,
    "m_FunctionName": "GetMultipleVision",
    "m_FunctionSource": "6a46b5003a7f38c41a0db6fa58b5af62",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "// Объявляем глобальные массивы, которые будем заполнять из C#\n#ifndef GLOBAL_VISION_VARS\n#define GLOBAL_VISION_VARS\n    uniform float4 _VisionZones[64]; // x,y,z - позиция, w - радиус\n    uniform int _VisionZonesCount;   // сколько зон сейчас активно\n#endif\n\nfloat visibility = 0.0;\n// Ограничиваем цикл, чтобы не выйти за пределы массива\nint count = min(_VisionZonesCount, 64);\n\nfor(int i = 0; i < count; i++)\n{\n    // Считаем дистанцию от пикселя до центра зоны\n    float dist = distance(WorldPos, _VisionZones[i].xyz);\n    \n    // Аналог твоей ноды Step. 1 - внутри радиуса, 0 - снаружи\n    float currentVis = step(dist, _VisionZones[i].w);\n    \n    // max объединяет зоны. Если пиксель попал хотя бы в одну зону, он будет видим (1)\n    visibility = max(visibility, currentVis);\n}\n\nVisibility = visibility;"
}

